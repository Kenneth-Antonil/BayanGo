rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isRider() {
      return isSignedIn() && request.auth.token.rider == true;
    }

    // Product images: admin-only write, authenticated read
    match /products/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Order proofs: riders/admin upload, authenticated read
    match /order_proofs/{orderId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isRider();
    }

    // Default deny all
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
