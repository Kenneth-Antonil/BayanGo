rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    // Public-facing images can be viewed by anyone with the URL.
    // Allow QR uploads from admin sessions even when Firebase Auth is delayed.
    function isImageUpload(maxBytes) {
      return request.resource != null
        && request.resource.contentType.matches("image/.*")
        && request.resource.size < maxBytes;
    }

    match /gcash_qr/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn() || isImageUpload(5 * 1024 * 1024);
    }

    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /product_images/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /order_proofs/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }


    match /merchant_logos/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn() && isImageUpload(5 * 1024 * 1024);
    }

    match /merchant_listing_images/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn() && isImageUpload(5 * 1024 * 1024);
    }

    match /merchant_banners/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn() && isImageUpload(5 * 1024 * 1024);
    }

    match /rider_profiles/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn() && isImageUpload(5 * 1024 * 1024);
    }

    // Default deny for any other object paths.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
