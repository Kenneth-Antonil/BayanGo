{
  "rules": {

    // ─────────────────────────────────────────────────────────────────────────
    // ADMIN REGISTRY
    // Only admins can read or write this node.
    // Bootstrap: manually add { "<your-uid>": true } via Firebase Console.
    // ─────────────────────────────────────────────────────────────────────────
    "admins": {
      ".read":  "auth != null && root.child('admins').child(auth.uid).val() === true",
      ".write": "auth != null && root.child('admins').child(auth.uid).val() === true"
    },

    // ─────────────────────────────────────────────────────────────────────────
    // RIDER REGISTRY
    // Only admins can grant/revoke rider status.
    // Each rider can read their own entry to know if they are still active.
    // ─────────────────────────────────────────────────────────────────────────
    "riders": {
      ".write": "auth != null && root.child('admins').child(auth.uid).val() === true",
      "$uid": {
        ".read": "auth != null && auth.uid === $uid"
      }
    },

    // ─────────────────────────────────────────────────────────────────────────
    // PRODUCTS
    // Any authenticated user can read. Only admins can write.
    // ─────────────────────────────────────────────────────────────────────────
    "products": {
      ".read":  "auth != null",
      ".write": "auth != null && root.child('admins').child(auth.uid).val() === true"
    },

    // ─────────────────────────────────────────────────────────────────────────
    // VOUCHERS
    // Any authenticated user can read. Only admins can write.
    // ─────────────────────────────────────────────────────────────────────────
    "vouchers": {
      ".read":  "auth != null",
      ".write": "auth != null && root.child('admins').child(auth.uid).val() === true"
    },

    // ─────────────────────────────────────────────────────────────────────────
    // APP SETTINGS  (gcash, marketPricing, pushVapidKey, etc.)
    // Any authenticated user can read. Only admins can write.
    // ─────────────────────────────────────────────────────────────────────────
    "settings": {
      ".read":  "auth != null",
      ".write": "auth != null && root.child('admins').child(auth.uid).val() === true"
    },

    // ─────────────────────────────────────────────────────────────────────────
    // ORDERS
    // - Admins & riders: full read on the collection (for dashboards / order lists)
    // - Customers: can query filtered by their own uid ONLY
    // - New order: any authenticated user, but uid must match their own auth.uid
    // - Update/delete: order owner (customer), admin, or rider
    // ─────────────────────────────────────────────────────────────────────────
    "orders": {
      ".indexOn": ["createdAt", "uid", "merchantId"],
      ".read": "auth != null && (
        root.child('admins').child(auth.uid).val() === true ||
        root.child('riders').child(auth.uid).val() === true ||
        root.child('partner_merchants').child(auth.uid).child('approved').val() === true ||
        (query.orderByChild === 'uid' && query.equalTo === auth.uid)
      )",
      "$orderId": {
        ".read": "auth != null && (
          data.child('uid').val() === auth.uid ||
          data.child('merchantId').val() === auth.uid ||
          root.child('admins').child(auth.uid).val() === true ||
          root.child('riders').child(auth.uid).val() === true
        )",
        ".write": "auth != null && (
          (!data.exists() && newData.child('uid').val() === auth.uid) ||
          (data.exists() && data.child('uid').val() === auth.uid) ||
          (data.exists() && data.child('merchantId').val() === auth.uid && root.child('partner_merchants').child(auth.uid).child('approved').val() === true) ||
          root.child('admins').child(auth.uid).val() === true ||
          root.child('riders').child(auth.uid).val() === true
        )",
        ".validate": "newData.hasChildren(['uid','status','items','createdAt'])"
      }
    },

    // ─────────────────────────────────────────────────────────────────────────
    // RIDER LOCATIONS
    // Any authenticated user can read (customers need to track their rider).
    // Only the rider themselves can write/remove their own location.
    // ─────────────────────────────────────────────────────────────────────────
    "rider_locations": {
      "$uid": {
        ".read":  "auth != null",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    // ─────────────────────────────────────────────────────────────────────────
    // PUSH TOKENS (FCM)
    // Users manage their own tokens only.
    // Admins can read all tokens (needed for broadcast notifications).
    // Cloud Functions use Admin SDK so they bypass rules automatically.
    // ─────────────────────────────────────────────────────────────────────────
    "push_tokens": {
      ".read":  "auth != null && root.child('admins').child(auth.uid).val() === true",
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },


    // ─────────────────────────────────────────────────────────────────────────
    // USER PROFILES
    // Users can read and write their own profile only.
    // Admins can read all profiles.
    // ─────────────────────────────────────────────────────────────────────────
    "users": {
      "$uid": {
        ".read":  "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).val() === true)",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    // ─────────────────────────────────────────────────────────────────────────
    // NOTIFICATION QUEUE
    // Riders push delivery-payment notifications here.
    // Cloud Functions read and clean up entries via Admin SDK (bypasses rules).
    // Admin can read/write for debugging.
    // ─────────────────────────────────────────────────────────────────────────
    "notification_queue": {
      ".read":  "auth != null && root.child('admins').child(auth.uid).val() === true",
      ".write": "auth != null && (
        root.child('admins').child(auth.uid).val() === true ||
        root.child('riders').child(auth.uid).val() === true
      )"
    },

    // ─────────────────────────────────────────────────────────────────────────
    // APP USAGE TELEMETRY
    // Users write their own install/activity data only.
    // Admins can read all telemetry.
    // ─────────────────────────────────────────────────────────────────────────
    "app_usage": {
      ".read":  "auth != null && root.child('admins').child(auth.uid).val() === true",
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    // ─────────────────────────────────────────────────────────────────────────
    // NOTIFICATIONS
    // - Each user can read and write their own notifications.
    // - Admins can write to any user's notifications (e.g. approval alerts).
    // ─────────────────────────────────────────────────────────────────────────
    "notifications": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && (
          auth.uid === $uid ||
          root.child('admins').child(auth.uid).val() === true
        )"
      }
    },

    // ─────────────────────────────────────────────────────────────────────────
    // USER NOTIFICATIONS (written by Cloud Functions via Admin SDK)
    // Each user can read their own notifications.
    // Only Cloud Functions (Admin SDK) and admins can write.
    // ─────────────────────────────────────────────────────────────────────────
    "user_notifications": {
      "$uid": {
        ".indexOn": ["createdAt"],
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && root.child('admins').child(auth.uid).val() === true"
      }
    },

    // ─────────────────────────────────────────────────────────────────────────
    // SUPPORT TICKETS
    // Users can create tickets (uid must match) and read their own via query.
    // Admins can read all and update any ticket (assign, change status).
    // ─────────────────────────────────────────────────────────────────────────
    "support_tickets": {
      ".indexOn": ["createdAt", "uid"],
      ".read": "auth != null && (
        root.child('admins').child(auth.uid).val() === true ||
        (query.orderByChild === 'uid' && query.equalTo === auth.uid)
      )",
      "$ticketId": {
        ".read": "auth != null && (
          data.child('uid').val() === auth.uid ||
          root.child('admins').child(auth.uid).val() === true
        )",
        ".write": "auth != null && (
          (!data.exists() && newData.child('uid').val() === auth.uid) ||
          root.child('admins').child(auth.uid).val() === true ||
          (data.exists() && data.child('uid').val() === auth.uid)
        )"
      }
    },

    // ─────────────────────────────────────────────────────────────────────────
    // SUPPORT MESSAGES
    // Users can read/write messages on their own tickets.
    // Admins can read/write messages on any ticket.
    // ─────────────────────────────────────────────────────────────────────────
    "support_messages": {
      "$ticketId": {
        ".indexOn": ["createdAt"],
        ".read": "auth != null && (
          root.child('support_tickets').child($ticketId).child('uid').val() === auth.uid ||
          root.child('admins').child(auth.uid).val() === true
        )",
        ".write": "auth != null && (
          root.child('support_tickets').child($ticketId).child('uid').val() === auth.uid ||
          root.child('admins').child(auth.uid).val() === true
        )"
      }
    },

    // ─────────────────────────────────────────────────────────────────────────
    // SUPPORT CALLS (WebRTC signaling)
    // Users can create calls and read/write their own.
    // Admins can read/write calls assigned to them.
    // ─────────────────────────────────────────────────────────────────────────
    "support_calls": {
      "$callId": {
        ".read": "auth != null && (
          data.child('uid').val() === auth.uid ||
          data.child('assignedAdminUid').val() === auth.uid ||
          root.child('admins').child(auth.uid).val() === true
        )",
        ".write": "auth != null && (
          (!data.exists() && newData.child('uid').val() === auth.uid) ||
          data.child('uid').val() === auth.uid ||
          data.child('assignedAdminUid').val() === auth.uid ||
          root.child('admins').child(auth.uid).val() === true
        )"
      }
    },

    // ─────────────────────────────────────────────────────────────────────────
    // SUPPORT CALL SIGNALS (ICE candidates for WebRTC)
    // Same access as the parent call.
    // ─────────────────────────────────────────────────────────────────────────
    "support_call_signals": {
      "$callId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },

    // ─────────────────────────────────────────────────────────────────────────
    // SUPPORT CALL PRESENCE (admin online/busy status)
    // Admins write their own presence. Users can read (to check availability).
    // ─────────────────────────────────────────────────────────────────────────
    "support_call_presence": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && (
          auth.uid === $uid ||
          root.child('admins').child(auth.uid).val() === true
        )"
      }
    },

    // ─────────────────────────────────────────────────────────────────────────
    // SUPPORT CALL QUEUE (queued calls when admin is busy)
    // Admins manage their own queue. Users can write to queue their call.
    // ─────────────────────────────────────────────────────────────────────────
    // ─────────────────────────────────────────────────────────────────────────
    // PARTNER APPLICATIONS
    // Authenticated users can create applications (applicantUid must match).
    // Applicants can read their own applications.
    // Admins can read all and update status (approve/reject).
    // ─────────────────────────────────────────────────────────────────────────
    "partner_applications": {
      ".indexOn": ["createdAt", "applicantUid"],
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
      "$appId": {
        ".read": "auth != null && (
          data.child('applicantUid').val() === auth.uid ||
          root.child('admins').child(auth.uid).val() === true
        )",
        ".write": "auth != null && (
          (!data.exists() && newData.child('applicantUid').val() === auth.uid) ||
          (data.exists() && data.child('applicantUid').val() === auth.uid && data.child('status').val() !== 'approved' && data.child('status').val() !== 'rejected') ||
          root.child('admins').child(auth.uid).val() === true
        )"
      }
    },

    // Legacy mirror path for merchant applications.
    // Keep same access rules as partner_applications for backward compatibility.
    "merchant_applications": {
      ".indexOn": ["createdAt", "applicantUid"],
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
      "$appId": {
        ".read": "auth != null && (
          data.child('applicantUid').val() === auth.uid ||
          root.child('admins').child(auth.uid).val() === true
        )",
        ".write": "auth != null && (
          (!data.exists() && newData.child('applicantUid').val() === auth.uid) ||
          (data.exists() && data.child('applicantUid').val() === auth.uid && data.child('status').val() !== 'approved' && data.child('status').val() !== 'rejected') ||
          root.child('admins').child(auth.uid).val() === true
        )"
      }
    },

    // Legacy typo path kept for historical data compatibility.
    // Some older clients wrote to "mechant_applications" (missing "r").
    "mechant_applications": {
      ".indexOn": ["createdAt", "applicantUid"],
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
      "$appId": {
        ".read": "auth != null && (
          data.child('applicantUid').val() === auth.uid ||
          root.child('admins').child(auth.uid).val() === true
        )",
        ".write": "auth != null && (
          (!data.exists() && newData.child('applicantUid').val() === auth.uid) ||
          (data.exists() && data.child('applicantUid').val() === auth.uid && data.child('status').val() !== 'approved' && data.child('status').val() !== 'rejected') ||
          root.child('admins').child(auth.uid).val() === true
        )"
      }
    },

    // ─────────────────────────────────────────────────────────────────────────
    // PARTNER MERCHANTS
    // Merchants can read/write their own record.
    // Admins can read/write all (for approval workflow).
    // Any authenticated user can read (to browse merchant stores).
    // ─────────────────────────────────────────────────────────────────────────
    "partner_merchants": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && (
          auth.uid === $uid ||
          root.child('admins').child(auth.uid).val() === true
        )"
      }
    },

    // ─────────────────────────────────────────────────────────────────────────
    // MERCHANT LISTINGS (products per merchant)
    // Any authenticated user can read. Merchant owner or admin can write.
    // ─────────────────────────────────────────────────────────────────────────
    "merchant_listings": {
      ".read": "auth != null",
      "$merchantId": {
        ".write": "auth != null && (
          auth.uid === $merchantId ||
          root.child('admins').child(auth.uid).val() === true
        )"
      }
    },

    "support_call_queue": {
      "$adminUid": {
        ".read": "auth != null && (
          auth.uid === $adminUid ||
          root.child('admins').child(auth.uid).val() === true
        )",
        ".write": "auth != null"
      }
    },

    // ─────────────────────────────────────────────────────────────────────────
    // DELIVERY RATINGS
    // Users can create ratings for their own orders (uid must match).
    // Anyone authenticated can read (riders see their ratings, users see rider profiles).
    // Admins can read/write all.
    // ─────────────────────────────────────────────────────────────────────────
    "delivery_ratings": {
      ".indexOn": ["riderId", "uid", "orderId", "createdAt"],
      ".read": "auth != null",
      "$ratingId": {
        ".write": "auth != null && (
          (!data.exists() && newData.child('uid').val() === auth.uid) ||
          (data.exists() && data.child('uid').val() === auth.uid) ||
          root.child('admins').child(auth.uid).val() === true
        )",
        ".validate": "newData.hasChildren(['uid', 'orderId', 'riderId', 'riderRating', 'createdAt'])"
      }
    },

    // ─────────────────────────────────────────────────────────────────────────
    // REFUNDS
    // Admins create/manage refunds. Users can query their own refunds.
    // Push notifications are sent via Cloud Functions on creation.
    // ─────────────────────────────────────────────────────────────────────────
    "refunds": {
      ".indexOn": ["createdAt", "uid", "orderId"],
      ".read": "auth != null && (
        root.child('admins').child(auth.uid).val() === true ||
        (query.orderByChild === 'uid' && query.equalTo === auth.uid)
      )",
      "$refundId": {
        ".read": "auth != null && (
          data.child('uid').val() === auth.uid ||
          root.child('admins').child(auth.uid).val() === true
        )",
        ".write": "auth != null && root.child('admins').child(auth.uid).val() === true",
        ".validate": "newData.hasChildren(['uid', 'orderId', 'amount', 'reason', 'status', 'createdAt'])"
      }
    },

    // ─────────────────────────────────────────────────────────────────────────
    // RIDER PROFILES (public-facing profile data)
    // Riders can write their own profile (photo, name).
    // Anyone authenticated can read (for rating display).
    // ─────────────────────────────────────────────────────────────────────────
    "rider_profiles": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && (
          auth.uid === $uid ||
          root.child('admins').child(auth.uid).val() === true
        )"
      }
    }

  }
}
